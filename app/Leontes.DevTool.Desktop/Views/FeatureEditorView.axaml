<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Leontes.DevTool.Desktop.ViewModels"
             x:Class="Leontes.DevTool.Desktop.Views.FeatureEditorView"
             x:DataType="vm:FeatureEditorViewModel">

    <Border Classes="card" Padding="0">
        <ScrollViewer Padding="22">
            <StackPanel Spacing="12" MaxWidth="760">
                <TextBlock Classes="title" Text="Feature"/>

                <TextBlock Text="Name" Classes="section"/>
                <TextBox Text="{Binding Name}"/>

                <TextBlock Text="Description" Classes="section"/>
                <TextBox Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                <TextBlock Text="Feature context" Classes="section"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Layered on top of the project's general context and inherited by every task in this feature."/>
                <TextBox Text="{Binding FeatureContext}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160"/>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Save" Classes="accent" Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding Status}" Classes="muted" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
