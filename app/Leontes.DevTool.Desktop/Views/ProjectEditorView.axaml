<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Leontes.DevTool.Desktop.ViewModels"
             x:Class="Leontes.DevTool.Desktop.Views.ProjectEditorView"
             x:DataType="vm:ProjectEditorViewModel">

    <Border Classes="card" Padding="0">
        <ScrollViewer Padding="22">
            <StackPanel Spacing="12" MaxWidth="760">
                <TextBlock Classes="title" Text="Project"/>
                <TextBlock Classes="subtitle" Text="{Binding RootFolderPath}"/>

                <TextBlock Text="Name" Classes="section"/>
                <TextBox Text="{Binding Name}"/>

                <TextBlock Text="Description" Classes="section"/>
                <TextBox Text="{Binding Description}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                <TextBlock Text="General context" Classes="section"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Inherited by every feature and task below. e.g. 'We are rewriting a legacy app; behavior must match the old app unless the ticket says otherwise.'"/>
                <TextBox Text="{Binding GeneralContext}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="160"/>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Jira project key"/>
                        <TextBox Text="{Binding JiraProjectKey}" Watermark="MA"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="GitHub owner"/>
                        <TextBox Text="{Binding GitHubOwner}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="GitHub repo"/>
                        <TextBox Text="{Binding GitHubRepo}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Save" Classes="accent" Command="{Binding SaveCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding Status}" Classes="muted" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
